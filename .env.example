# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
AUTHORIZED_USER_ID=your_telegram_user_id_here

# GitHub webhook (optional — for webhook.ts auto-deploy)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Service hostnames (optional — defaults shown)
PROMETHEUS_HOST=prometheus
GRAFANA_HOST=grafana
NPM_HOST=nginx-proxy-manager

# Grafana VPN/Tailscale fallback URL (used when internal Docker network check fails)
# Grafana public access is intentionally disabled — only internal + VPN checks are valid.
GRAFANA_VPN_URL=http://100.75.253.104:3002/api/health
